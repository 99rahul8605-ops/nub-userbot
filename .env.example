# Telegram API credentials (required)
# Get from https://my.telegram.org
API_ID=
API_HASH=

# Pyrogram session string (required)
SESSION_STR=

# Bot token from @BotFather (required for inline/bot features)
BOT_TOKEN=

# Gemini API key (optional, for AI features)
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# YT_DLP API key (optional, for YouTube downloads)
YT_DLP_API_KEY=
# Optional: Base URL for the YT_DLP API
YT_DLP_BASE_URL=http://api.nubcoders.com

# Support group username without @ (optional)
GROUP=nub_coder_s

# Updates channel username without @ (optional)
CHANNEL=nub_coders

# MongoDB URI (optional — leave empty to use in-memory storage, lost on restart)
MONGO_URI=

# MongoDB database name (optional, defaults to "userbot")
DB_NAME=userbot

# Userbot account username without @ (optional)
USERBOT_USERNAME=
